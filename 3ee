	create table userr(
	id serial primary key,
	nome varchar (255) not null,
	email varchar(255) unique,
	senha varchar(255) not null,
	cpf varchar(11) unique not null,
	telefone varchar(11) not null
	);
	create table veiculo(
	id serial primary key,
	novo_veiculo varchar(255) not null, 
	modelo varchar(255) not null,
	marca varchar(255) not null,
	placa varchar(255) not null,
	ano int not null,
	estado varchar(255) not null,
	observacao varchar(255) not null

	);
	create table viagem( 
	id serial primary key,
	id_userr int not null, 
	id_veiculo int not null,
	nova_viagem varchar (255) not null,
	lista_viagem varchar (255) not null,
	data_criacao timestamp default current_timestamp,
	distancia_km varchar(255) not null,
	partida varchar(255) not null,
	destino varchar(255) not null,
	observacao varchar(255),
	conclusao varchar(255) not null,
	constraint fk_userr_viagem
		foreign key (id_userr) references userr(id)
		on delete cascade,
	constraint fk_veiculo_viagem
		foreign key (id_veiculo) references veiculo(id)
		on delete cascade
	);
	
	
	
	